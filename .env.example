# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# GigaChat (Sber). Ключ авторизации (Authorization key) из личного кабинета
# https://developers.sber.ru/studio  (раздел GigaChat API).
GIGACHAT_CREDENTIALS=
# Scope: GIGACHAT_API_PERS (физлица), GIGACHAT_API_B2B или GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat, GigaChat-Pro, GigaChat-Max и т.д.
GIGACHAT_MODEL=GigaChat
# Проверка SSL. false — проще для локального запуска (без установки Russian Trusted Root CA).
# Для продакшена: true и путь к сертификату в GIGACHAT_CA_BUNDLE_FILE.
GIGACHAT_VERIFY_SSL=false
GIGACHAT_CA_BUNDLE_FILE=

# Часовой пояс салона (например Europe/Moscow, Asia/Yekaterinburg)
SALON_TIMEZONE=Europe/Moscow

# Кому присылать уведомления о записях/отменах (личные сообщения от бота).
# Через запятую: @username и/или chat_id (узнать у @userinfobot).
# Каждый админ с @username должен один раз нажать /start у бота.
ADMIN_ACCOUNTS=@your_admin,@second_admin

# Google Calendar (необязательно). Включить синхронизацию записей с календарём.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
